# Environment Variables Example
# انسخ هذا الملف إلى .env وعدّل القيم حسب احتياجاتك

# PORT - رقم المنفذ
PORT=3000

# NODE_ENV - بيئة التطوير
NODE_ENV=development

# DATABASE_PATH - مسار قاعدة البيانات
DATABASE_PATH=./medicine_bank.db

# MAX_UPLOAD_SIZE - أقصى حجم للملف المرفوع
MAX_UPLOAD_SIZE=50mb

# ALLOWED_FILE_TYPES - أنواع الملفات المسموحة
ALLOWED_FILE_TYPES=xlsx,xls

# APP_NAME - اسم التطبيق
APP_NAME=Yemen Medicine Bank - Dhamar Branch

# APP_VERSION - إصدار التطبيق
APP_VERSION=1.0.0

# LANGUAGE - لغة التطبيق الأساسية
LANGUAGE=ar
